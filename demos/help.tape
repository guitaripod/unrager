# Help overlay — full key bindings.
Output demos/out/help.gif
Output demos/out/help.mp4

Set Shell "bash"
Set FontSize 14
Set Width 1600
Set Height 960
Set Padding 20
Set Margin 0
Set Theme "Catppuccin Mocha"
Set TypingSpeed 60ms

Type "UNRAGER_DISABLE_KITTY=1 ./target/release/unrager"
Enter
Sleep 5s
Type "?"
Sleep 1500ms
Screenshot demos/out/help.png
Type " "
Sleep 400ms
Type "q"
Sleep 400ms
